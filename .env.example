# ===========================================
# LEGO MOC Builder (BrickWise) - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to git.
# Production uses AWS Secrets Manager (see task 1.6).
# ===========================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@ep-xyz.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Authentication ---
JWT_SECRET=generate-a-random-256-bit-key-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- AI Recognition (AWS Bedrock) ---
AWS_REGION=us-east-1
# AWS credentials are loaded from ~/.aws/credentials or environment
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Rebrickable API ---
REBRICKABLE_API_KEY=your-rebrickable-api-key

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=brickwise-scan-images
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# --- Server ---
PORT=8080
NODE_ENV=development

# --- BrickLink API (optional, for pricing) ---
# BRICKLINK_CONSUMER_KEY=
# BRICKLINK_CONSUMER_SECRET=
# BRICKLINK_TOKEN=
# BRICKLINK_TOKEN_SECRET=

# --- BrickOwl API (optional, for pricing) ---
# BRICKOWL_API_KEY=
